# Neon Database Configuration
# Copy this file to .env and fill in your actual database URL

# Recommended for most uses (with connection pooling)
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require

# For uses requiring a connection without pgbouncer
# DATABASE_URL_UNPOOLED=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require

# Server port
PORT=5000
